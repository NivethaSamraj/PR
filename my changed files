 * Self-Healing Flow Dashboard
 * ---------------------------
 * Drop-in replacement for the previous renderHtml(flows, outDir).
 * Every figure on the page is derived from the live `flows[]` array that
 * flowTracker collects during the run. Nothing is hardcoded — if a tier has
 * zero entries the bar/segment simply renders at zero width.
 */

const esc = (s?: string | number | null) =>
  String(s ?? "—")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");


const displayNames: Record<string, string> = {
  continue_shopping: "Dismiss Welcome Popup",
  search_toggle: "Open Product Search",
  search_input: "Enter Search Criteria",
  dress_product: "Select Product",
  dress_size: "Choose Size",
  add_to_bag: "Add Product To Bag",
  mini_cart_open: "Open Shopping Bag",
  verify_cart: "Verify Cart Contents"
};

const TIER_META = {
  db: { label: "DB Primary", color: "#2DD4A7" },
  smart: { label: "Smart Locator", color: "#F4B740" },
  ai: { label: "AI Healed", color: "#FF6B6B" },
  unresolved: { label: "Unresolved", color: "#6B7A99" },
} as const;

type TierKey = keyof typeof TIER_META;

function pct(n: number, total: number): number {
  return total === 0 ? 0 : Math.round((n / total) * 1000) / 10;
}

export function renderHtml(flows: HealFlow[], outDir: string): string {
