async function generateStableCss(
  page: Page,
  meta: any
): Promise<string | undefined> {

  const candidates = [

    {
      attr: 'data-testid',
      value: meta.testId
    },

    {
      attr: 'data-test',
      value: meta.dataTest
    },

    {
      attr: 'aria-label',
      value: meta.label
    },

    {
      attr: 'placeholder',
      value: meta.placeholder
    },

    {
      attr: 'name',
      value: meta.name
    },

    {
      attr: 'title',
      value: meta.title
    },

    {
      attr: 'alt',
      value: meta.alt
    },

    {
      attr: 'id',
      value: meta.id
    }
  ];

  for (const candidate of candidates) {

    if (
      !candidate.value ||
      !isCleanValue(
        candidate.value,
        candidate.attr
      )
    ) {
      continue;
    }

    const selector =
      candidate.attr === 'id'
        ? `#${candidate.value}`
        : `${meta.tag}[${candidate.attr}="${candidate.value}"]`;

    if (
      await isUniqueCss(
        page,
        selector
      )
    ) {
      return selector;
    }
  }

  if (meta.class) {

    const stableClass =
      meta.class
        .split(' ')
        .find(
          (c: string) =>
            isCleanValue(
              c,
              'class'
            )
        );

    if (stableClass) {

      const selector =
        `${meta.tag}.${stableClass}`;

      if (
        await isUniqueCss(
          page,
          selector
        )
      ) {
        return selector;
      }
    }
  }

  return undefined;
}

