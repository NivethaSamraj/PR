  const healedN = flows.filter((f) => f.healed).length;
  const resolvedN = total - unresolvedN;

  // Resilience score: share of elements resolved at ANY tier without manual help
  const resilience = pct(resolvedN, total);

  // // Avg steps to resolve (depth of fallback chain actually used)
  // const totalSteps = flows.reduce((a, f) => a + (f.steps?.length ?? 0), 0);
  // const avgSteps = total === 0 ? 0 : Math.round((totalSteps / total) * 10) / 10;

  // Total time across all logged steps (ms) where durations exist
  const totalMs = flows.reduce(
    (a, f) => a + (f.steps?.reduce((s, st) => s + (st.durationMs ?? 0), 0) ?? 0),
    0
  );

  // ---- Tier distribution bar (segments scale to live counts) ----
  const distOrder: TierKey[] = ["db", "smart", "ai", "unresolved"];
