import fs from "fs";
import path from "path";

export type Tier = "db" | "smart" | "ai";
export type Status = "success" | "failed" | "skipped";

export interface FlowStep {
  order: number;
  tier: Tier;
  action: string;
  locator?: string;
  status: Status;
  reason?: string;
  durationMs?: number;
}

export interface HealFlow {
  elementName: string;
  testName: string;
  pageUrl: string;
  startedAt: string;
  steps: FlowStep[];
  finalTier: Tier | null;
  finalLocator: string | null;
  healed: boolean;
  writtenBack: boolean;
}

const OUT = "self-healing-output";
const SHARD_DIR = path.join(OUT, "shards");

let currentFlow: HealFlow | null = null;
const allFlows: HealFlow[] = [];

export function beginFlow(
  elementName: string,
  testName: string,
  pageUrl: string
) {

  if (currentFlow) {
    console.log(
      'AUTO-CLOSING FLOW:',
      currentFlow.elementName
    );

    endFlow({
      finalTier: null,
      finalLocator: null,
      healed: false,
      writtenBack: false
    });
  }

  console.log('BEGIN FLOW:', elementName);

  currentFlow = {
    elementName,
    testName,
    pageUrl,
    startedAt: new Date().toISOString(),
    steps: [],
    finalTier: null,
    finalLocator: null,
    healed: false,
    writtenBack: false
  };
}
export function logStep(
  step: Omit<FlowStep, "order">
) {
  if (!currentFlow) return;

  currentFlow.steps.push({
    order: currentFlow.steps.length + 1,
    ...step,
  });
}

export function endFlow(opts: any) {
  console.log('END FLOW');
    console.log(
    'ENDING FLOW',
    currentFlow?.elementName,
    opts.finalTier
  );

  if (!currentFlow) {
    console.log('NO CURRENT FLOW');
    return;
  }

  Object.assign(currentFlow, opts);

  allFlows.push(currentFlow);

  console.log(
    'FLOW COUNT:',
    allFlows.length
  );

  currentFlow = null;

  writeShard();
}

export function getFlows(): HealFlow[] {
  return allFlows;
}

function writeShard() {
  try {
    fs.mkdirSync(SHARD_DIR, { recursive: true });

    const file = path.join(
      SHARD_DIR,
      `flows-${process.pid}.json`
    );

    fs.writeFileSync(
      file,
      JSON.stringify(allFlows, null, 2),
      "utf-8"
    );
  } catch (e) {
    console.error("Failed to write shard", e);
  }
}













