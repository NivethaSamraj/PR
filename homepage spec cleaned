import { test, expect } from '@playwright/test';
import { step, dismissWelcomePopup } from '../core/healing/stepRunner';

/* ================================================================== *
 *  SPEC — Ann Taylor full funnel: homepage → PLP → PDP → cart
 *
 *  All self-healing logic (capture, DB/smart resolution, AI heal,
 *  flow tracking) lives in core/healing/stepRunner. This file holds
 *  only the test scenario: the elements, their candidate locators,
 *  and the action performed on each.
 * ================================================================== */
test.describe('Ann Taylor — Self-Healing Funnel', () => {
  test('homepage to bag interactions', async ({ page }) => {
    test.setTimeout(180_000);

    await page.goto('https://sfqa.anntaylor.com/', {
      waitUntil: 'domcontentloaded',
    });
    await page.waitForLoadState('domcontentloaded');

    // DISMISS WELCOME POPUP
    // The EShopWorld welcome modal (div.modalBg.welcomeBg) overlays the page
    // and intercepts pointer events. It must be closed before any click.
    // stepRunner also clears it again before each guarded action in case it
    // re-fires after navigation, so this upfront call is the first line of
    // defence rather than the only one.
    await dismissWelcomePopup(page);

    // SEARCH ICON
    await step(
      page,
      'search_toggle',
      [
        page.locator('[data-testid="search-icon"]'),
        page.getByRole('button', { name: /search/i }),
        page.locator('button[aria-label*="search" i]'),
      ],
      '[data-testid="search-icon"]',
      async (loc) => {
        await loc.click();
      },
      'Open Search'
    );

    // SEARCH INPUT
    await step(
      page,
      'search_input',
      [
        page.locator('input[name="q"]'),
        page.locator('input[data-search-field]'),
        page.getByPlaceholder('What are you looking for?'),
        page.getByRole('combobox', { name: /search/i }),
      ],
      'input[name="q"]',
      async (loc) => {
        // The search box only appears after the toggle opens the panel, so
        // wait for it to actually be present before interacting/capturing.
        await loc.waitFor({ state: 'visible', timeout: 10000 });
        await loc.click();
        await loc.fill('dress');

        // Enter alone only opens the suggestions dropdown on this site and
        // does NOT navigate, so we commit the search via the dropdown.
        // Suggestions render inside #search-results (aria-owns).
        await page.waitForTimeout(1500); // let suggestions populate

        // Prefer a "view all results" link; fall back to first suggestion;
        // last resort is Enter in case some builds do navigate.
        const viewAll = page.getByRole('link', {
          name: /see all|view all|all results|view results/i,
        });
        const firstSuggestion = page
          .locator('#search-results a, #search-results [role="option"]')
          .first();

        if (await viewAll.first().isVisible().catch(() => false)) {
          await viewAll.first().click();
        } else if (await firstSuggestion.isVisible().catch(() => false)) {
          await firstSuggestion.click();
        } else {
          await loc.press('Enter');
        }

        // Confirm we actually left the homepage for a results/PLP page.
        await page.waitForURL(/search|q=dress|Search-Show/i, { timeout: 15000 });
        await page.waitForLoadState('networkidle');
      },
      'Search Dresses'
    );

    // Geo/welcome modal can re-fire after the search navigation.
    await dismissWelcomePopup(page, 3000);

    // FIRST PRODUCT
    await step(
      page,
      'dress_product',
      [
        page.locator('.product-tile a').first(),
        page.locator('a[href*="/p/"]').first(),
        page.locator('[data-testid*="product"]').first(),
      ],
      '[data-testid*="product"]',
      async (loc) => {
        await loc.click();
        await page.waitForLoadState('domcontentloaded');
      },
      'Open First Product'
    );

    // Modal can re-fire again on the PDP load.
    await dismissWelcomePopup(page, 3000);

    // SIZE
    await step(
      page,
      'dress_size',
      [
        page.getByRole('button', { name: /^XS$/i }),
        page.getByRole('button', { name: /^S$/i }),
        page.getByRole('button', { name: /^M$/i }),
        page.getByRole('button', { name: /^L$/i }),
      ],
      'button.size-option',
      async (loc) => {
        await loc.click();
      },
      'Select Size'
    );

    // ADD TO BAG
    await step(
      page,
      'add_to_bag',
      [
        page.locator('#addToCart'),
        page.getByRole('button', { name: /add to bag/i }),
        page.getByText(/add to bag/i),
      ],
      '#addToCart',
      async (loc) => {
        await loc.click();
      },
      'Add To Bag'
    );

    // MINI CART
    await step(
      page,
      'mini_cart_open',
      [
        page.locator('#miniCart'),
        page.getByRole('button', { name: /bag|cart/i }),
        page.locator('[data-testid="cart-link"]'),
      ],
      '#miniCart',
      async (loc) => {
        await loc.click();
      },
      'Open Mini Cart'
    );

    // FINAL ASSERTION
    await test.step('Verify Product Added To Cart', async () => {
      await expect(page.locator('body')).toContainText(/bag|cart|checkout/i);
    });
  });
});
